@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/skolar-dialog.css">
    <link rel="icon" type="image/png" href="~/assets/img/skolarlogo.png">
    <link rel="stylesheet" href="~/admin/admin.css" asp-append-version="true">
    <title>Skolar Administration</title>
</head>
<body>
    <script src="~/js/skolar-dialog.js"></script>

    <header class="admin-header">
        <div>
            <p class="admin-eyebrow">Skolar Administration</p>
            <h1>Let's get back to work, Admin!</h1>
        </div>
        <button type="button" class="admin-logout" onclick="logoutUser()">Log out</button>
    </header>

    <main class="admin-main">
        <section class="admin-summary">
            <div><strong id="openIssueCount">0</strong><span>Open session issues</span></div>
            <div><strong id="pendingReviewCount">0</strong><span>Pending review reports</span></div>
            <div><strong id="pendingVerificationCount">0</strong><span>Tutor verifications</span></div>
            <div><strong id="pendingWithdrawalCount">0</strong><span>Withdrawal requests</span></div>
            <div><strong id="resolvedItemCount">0</strong><span>Resolved items</span></div>
        </section>

        <div class="admin-tabs" role="tablist" aria-label="Moderation sections">
            <button type="button" class="admin-tab active" data-admin-tab="sessions">Session Issues</button>
            <button type="button" class="admin-tab" data-admin-tab="reviews">Reported Reviews</button>
            <button type="button" class="admin-tab" data-admin-tab="verifications">Tutor Verifications</button>
            <button type="button" class="admin-tab" data-admin-tab="withdrawals">Tutor Withdrawals</button>
        </div>

        <section id="sessionIssuesPanel" class="admin-panel">
            <div class="admin-toolbar">
                <div>
                    <h2>Reported sessions</h2>
                    <p>Review the learner report and tutor response before deciding.</p>
                </div>
                <select id="issueFilter" aria-label="Filter session issues">
                    <option value="open">Open</option>
                    <option value="all">All</option>
                    <option value="resolved">Resolved</option>
                </select>
            </div>

            <div id="adminIssueList" class="admin-issue-list">
                <div class="admin-empty">Loading session issues...</div>
            </div>
        </section>

        <section id="reviewReportsPanel" class="admin-panel" hidden>
            <div class="admin-toolbar">
                <div>
                    <h2>Reported reviews</h2>
                    <p>Keep appropriate reviews published or remove reviews that violate the guidelines.</p>
                </div>
                <select id="reviewReportFilter" aria-label="Filter review reports">
                    <option value="pending">Pending</option>
                    <option value="all">All</option>
                    <option value="resolved">Resolved</option>
                </select>
            </div>

            <div id="adminReviewList" class="admin-issue-list">
                <div class="admin-empty">Loading reported reviews...</div>
            </div>
        </section>

        <section id="tutorVerificationsPanel" class="admin-panel" hidden>
            <div class="admin-toolbar">
                <div>
                    <h2>Tutor identity verification</h2>
                    <p>Approve verified tutors before their profiles appear in learner search.</p>
                </div>
                <select id="verificationFilter" aria-label="Filter tutor verifications">
                    <option value="all">All</option>
                    <option value="pending">Needs Review</option>
                    <option value="rejected">Rejected</option>
                </select>
            </div>

            <div id="adminVerificationList" class="admin-issue-list">
                <div class="admin-empty">Loading tutor verifications...</div>
            </div>
        </section>

        <section id="tutorWithdrawalsPanel" class="admin-panel" hidden>
            <div class="admin-toolbar">
                <div>
                    <h2>GCash withdrawal requests</h2>
                    <p>Review requested tutor payouts and mark them after admin processing.</p>
                </div>
                <select id="withdrawalFilter" aria-label="Filter tutor withdrawals">
                    <option value="open">Open</option>
                    <option value="all">All</option>
                    <option value="released">Released</option>
                    <option value="rejected">Rejected</option>
                </select>
            </div>

            <div id="adminWithdrawalList" class="admin-issue-list">
                <div class="admin-empty">Loading tutor withdrawals...</div>
            </div>
        </section>
    </main>

    <div class="admin-modal" id="adminResolutionModal" hidden>
        <div class="admin-modal-backdrop" data-close-admin-modal></div>
        <div class="admin-modal-card" role="dialog" aria-modal="true" aria-labelledby="adminResolutionTitle">
            <button type="button" class="admin-modal-close" data-close-admin-modal aria-label="Close">×</button>
            <p class="admin-eyebrow">Administrative decision</p>
            <h2 id="adminResolutionTitle">Resolve session issue</h2>
            <div id="adminResolutionDetails" class="admin-resolution-details"></div>

            <label for="adminResolutionAction">Resolution</label>
            <select id="adminResolutionAction">
                <option value="complete">Mark session completed</option>
                <option value="cancel">Cancel session</option>
                <option value="requestinfo">Request more information</option>
            </select>

            <label for="adminResolutionNote">Administrative note</label>
            <textarea id="adminResolutionNote" maxlength="1000" placeholder="Explain the decision or information required..."></textarea>
            <p id="adminResolutionError" class="admin-form-message" role="alert"></p>

            <div class="admin-modal-actions">
                <button type="button" class="admin-secondary-btn" data-close-admin-modal>Cancel</button>
                <button type="button" class="admin-primary-btn" id="submitAdminResolution">Submit Decision</button>
            </div>
        </div>
    </div>

    <div class="admin-toast" id="adminToast" hidden role="status" aria-live="polite"></div>

    <script src="~/main-js/auth-guard.js"></script>
    <script>requireRole("admin");</script>
    <script src="~/admin/admin-issues.js" asp-append-version="true"></script>
</body>
</html>
