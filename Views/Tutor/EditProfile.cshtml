@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/skolar-dialog.css">
  <meta name="description" content="Skolar Edit Profile — Update your personal information, bio, and profile photo.">
  <title>Edit Profile — Skolar</title>
  <link rel="icon" type="image/png" href="~/assets/img/skolarlogo.png">
  <link rel="stylesheet" href="~/tutor/tutor-css/tutor-shared.css">
  <link rel="stylesheet" href="~/tutor/tutor-css/edit-profile.css">
</head>
<body>
    <script src="~/js/skolar-dialog.js"></script>

  <!-- ========== SIDEBAR ========== -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-top">
      <div class="logo">
        <img src="~/assets/img/skolarlogo.png" alt="Skolar Logo" class="logo-icon">
        <div class="logo-text-group">
          <span class="logo-title">Skolar</span>
          <span class="logo-subtitle">Tutor Portal</span>
        </div>
      </div>

      <nav class="nav-menu">
        <a href="/Tutor/TutorDashboard" class="nav-item" data-page="dashboard">
          <span class="svg-icon icon-01 nav-icon icon-size-20" aria-hidden="true"></span>
          <span>Dashboard</span>
        </a>
        <a href="/Tutor/Bookings" class="nav-item" data-page="bookings">
          <span class="svg-icon icon-02 nav-icon icon-size-20" aria-hidden="true"></span>
          <span>Bookings</span>
        </a>
        <a href="/Tutor/Reviews" class="nav-item" data-page="reviews">
          <span class="svg-icon icon-03 nav-icon icon-size-20" aria-hidden="true"></span>
          <span>Reviews</span>
        </a>
        <a href="/Tutor/Calendar" class="nav-item" data-page="calendar">
          <span class="svg-icon icon-04 nav-icon icon-size-20" aria-hidden="true"></span>
          <span>Calendar</span>
        </a>
        <a href="/Payment/TutorFinance" class="nav-item" data-page="finance">
          <span class="svg-icon icon-21 nav-icon icon-size-20" aria-hidden="true"></span>
          <span>Earnings &amp; Penalties</span>
        </a>
      </nav>
    </div>

    <div class="sidebar-bottom">
      <a href="/Tutor/EditProfile" class="nav-item active" data-page="edit-profile">
        <span class="svg-icon icon-05 nav-icon icon-size-20" aria-hidden="true"></span>
        <span>Edit Profile</span>
      </a>
      <a href="/Tutor/Settings" class="nav-item" data-page="settings">
        <span class="svg-icon icon-06 nav-icon icon-size-20" aria-hidden="true"></span>
        <span>Settings</span>
      </a>
      <div class="profile-card">
        <div class="profile-avatar-small" id="sidebarInitials">VL</div>
        <div class="profile-info">
          <span class="profile-name" id="sidebarName">Vannesa L. Cainong</span>
          <span class="profile-role">Professional Teacher</span>
        </div>
      </div>
    </div>
  </aside>

  <!-- Sidebar overlay for mobile -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- ========== MAIN WRAPPER ========== -->
  <div class="main-wrapper">

    <!-- ========== TOPBAR ========== -->
    <header class="topbar">
      <button class="hamburger" id="hamburger" aria-label="Toggle sidebar">
        <span class="svg-icon icon-07 icon-size-24" aria-hidden="true"></span>
      </button>
      <h1 class="page-title">Edit Profile</h1>
      <div class="topbar-right">
        <div class="notif-wrapper">
          <button class="notif-btn" id="notifBtn" type="button" aria-label="Notifications" aria-expanded="false">
            <span class="svg-icon icon-08 icon-size-22" aria-hidden="true"></span>
            <span class="notif-dot" id="notifDot" hidden></span>
          </button>
          <div class="notif-dropdown" id="notifDropdown">
            <div class="notif-dropdown-header">
              <span>Notifications</span>
              <span class="notif-unread-count" id="notifUnreadCount"></span>
            </div>
            <div class="notif-list" id="notifList">
              <div class="notif-empty">Loading notifications...</div>
            </div>
          </div>
        </div>
        <a href="/Tutor/EditProfile" class="topbar-avatar" id="topbarAvatar">T</a>
      </div>
    </header>

    <!-- ========== MAIN CONTENT ========== -->
    <main class="main-content">

      <!-- Card 1: Personal Information -->
      <div class="ep-card">
        <h2 class="ep-card-title">Personal Information</h2>

        <!-- Avatar Row -->
        <div class="ep-avatar-row">
          <div class="ep-avatar" id="epAvatar">
            <span class="svg-icon icon-12 icon-size-auto" aria-hidden="true"></span>
          </div>
          <button class="ep-upload-btn" id="epUploadBtn">
            <span class="svg-icon icon-13 icon-size-auto" aria-hidden="true"></span>
            Upload Photo
          </button>
          <button type="button" class="ep-remove-photo-btn" id="epRemovePhotoBtn">Remove Photo</button>
          <input type="file" id="epFileInput" class="ep-file-input" accept="image/*">
          <button class="ep-btn-tan ep-view-btn" id="epViewProfile">View Public Profile</button>
        </div>

        <!-- Form Fields -->
        <div class="ep-form-grid">
          <div class="ep-field">
            <label for="epFirstName">First Name</label>
            <input type="text" id="epFirstName" placeholder="Enter first name" minlength="2" maxlength="60">
          </div>
          <div class="ep-field">
            <label for="epLastName">Last Name</label>
            <input type="text" id="epLastName" placeholder="Enter last name" maxlength="60">
          </div>
          <div class="ep-field">
            <label for="epDisplayTitle">Display Title</label>
            <input type="text" id="epDisplayTitle" placeholder="e.g. Professional Teacher" minlength="3" maxlength="120">
          </div>
          <div class="ep-field">
            <label for="epGmail">Email</label>
            <input type="email" id="epGmail" readonly>
            <small>Account email cannot be edited from the profile.</small>
          </div>
          <div class="ep-field">
            <label for="epPhone">Phone Number</label>
            <input type="tel" id="epPhone" placeholder="Enter phone number" inputmode="tel" maxlength="13">
          </div>
          <div class="ep-field">
            <label for="epLocation">Location</label>
            <input type="text" id="epLocation" placeholder="Enter location" maxlength="80">
          </div>
        </div>

        <!-- Actions -->
        <div class="ep-actions">
          <button class="ep-btn-discard" id="epPersonalDiscard">Discard</button>
          <button class="ep-btn-tan" id="epPersonalSave">Save Changes</button>
        </div>
      </div>

      <!-- Card 2: About Me -->
      <div class="ep-card">
        <h2 class="ep-card-title">About Me</h2>

        <div class="ep-form-grid">
          <div class="ep-field full-width">
            <label for="epTagline">Short Tagline</label>
            <input type="text" id="epTagline" placeholder="A brief description about yourself" maxlength="120">
          </div>
          <div class="ep-field full-width">
            <label for="epBio">Full Bio</label>
            <textarea id="epBio" placeholder="Write a detailed bio about yourself, your teaching experience, and specializations..." minlength="20" maxlength="500"></textarea>
          </div>
          <div class="ep-stats-row">
            <div class="ep-field">
              <label for="epYearsExp">Years of Experience</label>
              <input type="text" id="epYearsExp" placeholder="e.g. 5 Years" maxlength="40">
            </div>
            <div class="ep-field">
              <label for="epStudentsTaught">Students Taught</label>
              <input type="text" id="epStudentsTaught" placeholder="e.g. 50+ Students" maxlength="40">
            </div>
            <div class="ep-field">
              <label for="epSessionRate">Session Rate</label>
              <input type="text" id="epSessionRate" placeholder="e.g. 500/hr" maxlength="20">
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="ep-actions">
          <button class="ep-btn-discard" id="epAboutDiscard">Discard</button>
          <button class="ep-btn-tan" id="epAboutSave">Save Changes</button>
        </div>
      </div>

      <!-- Card 3: Subjects Taught -->
      <div class="ep-card">
        <h2 class="ep-card-title">Subjects Taught</h2>
        
        <div class="ep-add-row">
          <div class="ep-field">
            <div class="ep-subject-picker" id="epSubjectPicker">
              <input type="text" id="epSubjectInput" placeholder="Choose a subject" maxlength="50" readonly autocomplete="off" aria-haspopup="listbox" aria-expanded="false" aria-controls="epSubjectMenu">
              <button type="button" class="ep-subject-toggle" id="epSubjectToggle" aria-label="Open subject list">
                <span class="ep-subject-arrow" aria-hidden="true"></span>
              </button>
              <div class="ep-subject-menu" id="epSubjectMenu" role="listbox" hidden></div>
            </div>
          </div>
          <button class="ep-btn-tan" id="epAddSubject">+ Add</button>
        </div>

        <div class="ep-subjects-list" id="epSubjectsList">
          <!-- Dynamic subject pills will be added here -->
        </div>

        <!-- Actions -->
        <div class="ep-actions">
          <button class="ep-btn-discard" id="epSubjectsDiscard">Discard</button>
          <button class="ep-btn-tan" id="epSubjectsSave">Save Changes</button>
        </div>
      </div>

    </main>
  </div>

  <!-- Toast Notification -->
  <div class="ep-toast" id="epToast"></div>
  <script src="~/main-js/auth-guard.js"></script>
  <script>
    requireRole("tutor");
  </script>



  <script src="~/tutor/tutor-js/tutor-shared.js"></script>
  <script src="~/tutor/tutor-js/edit-profile.js"></script>
</body>
</html>
