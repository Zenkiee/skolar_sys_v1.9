@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/skolar-dialog.css">
  <meta name="description" content="Skolar Bookings — Manage all tutoring session requests and student information.">
  <title>Bookings — Skolar</title>
  <link rel="icon" type="image/png" href="~/assets/img/skolarlogo.png">
  <link rel="stylesheet" href="~/tutor/tutor-css/tutor-shared.css">
  <link rel="stylesheet" href="~/tutor/tutor-css/bookings.css">

</head>
<body>
    <script src="~/js/skolar-dialog.js"></script>

  <!-- ========== SIDEBAR ========== -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-top">
      <div class="logo">
        <img src="~/assets/img/skolarlogo.png" alt="Skolar Logo" class="logo-icon">
        <div class="logo-text-group">
          <span class="logo-title">Skolar</span>
          <span class="logo-subtitle">Tutor Portal</span>
        </div>
      </div>

      <nav class="nav-menu">
        <a href="/Tutor/TutorDashboard" class="nav-item" data-page="dashboard">
          <span class="svg-icon icon-01 nav-icon icon-size-20" aria-hidden="true"></span>
          <span>Dashboard</span>
        </a>
        <a href="/Tutor/Bookings" class="nav-item active" data-page="bookings">
          <span class="svg-icon icon-02 nav-icon icon-size-20" aria-hidden="true"></span>
          <span>Bookings</span>
        </a>
        <a href="/Tutor/Reviews" class="nav-item" data-page="reviews">
          <span class="svg-icon icon-03 nav-icon icon-size-20" aria-hidden="true"></span>
          <span>Reviews</span>
        </a>
        <a href="/Tutor/Calendar" class="nav-item" data-page="calendar">
          <span class="svg-icon icon-04 nav-icon icon-size-20" aria-hidden="true"></span>
          <span>Calendar</span>
        </a>
        <a href="/Payment/TutorFinance" class="nav-item" data-page="finance">
          <span class="svg-icon icon-21 nav-icon icon-size-20" aria-hidden="true"></span>
          <span>Earnings &amp; Penalties</span>
        </a>
      </nav>
    </div>

    <div class="sidebar-bottom">
      <a href="/Tutor/EditProfile" class="nav-item" data-page="edit-profile">
        <span class="svg-icon icon-05 nav-icon icon-size-20" aria-hidden="true"></span>
        <span>Edit Profile</span>
      </a>
      <a href="/Tutor/Settings" class="nav-item" data-page="settings">
        <span class="svg-icon icon-06 nav-icon icon-size-20" aria-hidden="true"></span>
        <span>Settings</span>
      </a>
      <div class="profile-card">
        <div class="profile-avatar-small" id="sidebarInitials">VL</div>
        <div class="profile-info">
          <span class="profile-name" id="sidebarName">Vannesa L. Cainong</span>
          <span class="profile-role">Professional Teacher</span>
        </div>
      </div>
    </div>
  </aside>

  <!-- Sidebar overlay for mobile -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- ========== MAIN WRAPPER ========== -->
  <div class="main-wrapper">

    <!-- ========== TOPBAR ========== -->
    <header class="topbar">
      <button class="hamburger" id="hamburger" aria-label="Toggle sidebar">
        <span class="svg-icon icon-07 icon-size-24" aria-hidden="true"></span>
      </button>
      <h1 class="page-title">Bookings</h1>
      <div class="topbar-right">
        <div class="notif-wrapper">
          <button class="notif-btn" id="notifBtn" type="button" aria-label="Notifications" aria-expanded="false">
            <span class="svg-icon icon-08 icon-size-22" aria-hidden="true"></span>
            <span class="notif-dot" id="notifDot" hidden></span>
          </button>
          <div class="notif-dropdown" id="notifDropdown">
            <div class="notif-dropdown-header">
              <span>Notifications</span>
              <span class="notif-unread-count" id="notifUnreadCount"></span>
            </div>
            <div class="notif-list" id="notifList">
              <div class="notif-empty">Loading notifications...</div>
            </div>
          </div>
        </div>
        <a href="/Tutor/EditProfile" class="topbar-avatar" id="topbarAvatar">T</a>
      </div>
    </header>

    <!-- ========== MAIN CONTENT ========== -->
    <main class="main-content">

      <!-- Subtitle -->
      <p class="bk-subtitle">Manage all session requests and student information</p>

      <!-- Search Bar -->
      <div class="bk-search-bar">
        <span class="svg-icon icon-09 icon-size-20" aria-hidden="true"></span>
        <input type="text" id="bookingsSearch" class="bk-search-input" placeholder="Search by name or subject">
      </div>

      <!-- Filter Buttons -->
      <div class="bk-filter-row">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="pending">Pending</button>
        <button class="filter-btn" data-filter="confirmed">Confirmed</button>
        <button class="filter-btn" data-filter="issue">Issues</button>
        <button class="filter-btn" data-filter="done">Done</button>
        <button class="filter-btn" data-filter="rejected">Rejected</button>
      </div>

      <!-- Bookings Table -->
      <div class="bk-table-card">
        <div class="bk-table-scroll">
          <table class="bk-full-table">
            <thead>
              <tr>
                <th>Student</th>
                <th>Subject</th>
                <th>Schedule</th>
                <th>Sessions</th>
                <th>Requested</th>
                <th>Email</th>
                <th>Contact</th>
                <th>Status</th>
                <th>Payment</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="bookingsTableBody"></tbody>
          </table>
        </div>
      </div>

    </main>
  </div>
  <div class="bk-modal" id="bookingDatesModal" hidden>
    <div class="bk-modal-backdrop" data-close-booking-modal></div>
    <div class="bk-modal-card" role="dialog" aria-modal="true" aria-labelledby="bookingDatesTitle">
      <div class="bk-modal-header">
        <div>
          <span class="bk-modal-label">Grouped request</span>
          <h2 id="bookingDatesTitle">Selected Dates</h2>
        </div>
        <button type="button" class="bk-modal-close" data-close-booking-modal aria-label="Close">×</button>
      </div>
      <p class="bk-modal-summary" id="bookingDatesSummary"></p>
      <div class="bk-modal-dates" id="bookingDatesList"></div>
    </div>
  </div>

  <div class="bk-modal bk-completion-modal" id="completeSessionModal" hidden>
    <div class="bk-modal-backdrop" data-close-completion-modal></div>
    <div class="bk-modal-card bk-completion-card" role="dialog" aria-modal="true" aria-labelledby="completeSessionTitle" aria-describedby="completeSessionDescription">
      <button type="button" class="bk-modal-close bk-completion-close" data-close-completion-modal aria-label="Close">×</button>
      <div class="bk-completion-icon" aria-hidden="true">✓</div>
      <h2 id="completeSessionTitle">Mark session as done?</h2>
      <p id="completeSessionDescription">The learner will be asked to confirm that this session was completed.</p>
      <div class="bk-completion-details" id="completeSessionDetails"></div>
      <div class="bk-completion-actions">
        <button type="button" class="bk-completion-cancel" data-close-completion-modal>Cancel</button>
        <button type="button" class="bk-completion-confirm" id="confirmCompleteSessionBtn">Mark as Done</button>
      </div>
    </div>
  </div>

  <div class="bk-modal bk-issue-response-modal" id="issueResponseModal" hidden>
    <div class="bk-modal-backdrop" data-close-issue-response-modal></div>
    <div class="bk-modal-card bk-issue-response-card" role="dialog" aria-modal="true" aria-labelledby="issueResponseTitle">
      <button type="button" class="bk-modal-close" data-close-issue-response-modal aria-label="Close">×</button>
      <span class="bk-modal-label">Session dispute</span>
      <h2 id="issueResponseTitle">Respond to learner issue</h2>
      <div class="bk-issue-session" id="issueResponseSession"></div>
      <div class="bk-learner-issue">
        <strong>Learner report</strong>
        <p id="issueResponseLearnerReason"></p>
      </div>
      <label for="issueResponseText">Your response</label>
      <textarea id="issueResponseText" maxlength="1000" placeholder="Explain what happened and provide relevant details..."></textarea>
      <div class="bk-issue-response-meta">
        <small>Your response can be edited until an administrator resolves the issue.</small>
        <span id="issueResponseCount">0/1000</span>
      </div>
      <p class="bk-issue-response-error" id="issueResponseError" role="alert"></p>
      <div class="bk-completion-actions">
        <button type="button" class="bk-completion-cancel" data-close-issue-response-modal>Cancel</button>
        <button type="button" class="bk-completion-confirm" id="submitIssueResponseBtn">Submit Response</button>
      </div>
    </div>
  </div>

  <div class="bk-modal" id="tutorCancellationModal" hidden>
    <div class="bk-modal-backdrop" data-close-tutor-cancellation></div>
    <div class="bk-modal-card bk-cancellation-card" role="dialog" aria-modal="true" aria-labelledby="tutorCancellationTitle">
      <button type="button" class="bk-modal-close" data-close-tutor-cancellation aria-label="Close">×</button>
      <span class="bk-modal-label">Cancellation policy</span>
      <h2 id="tutorCancellationTitle">Cancel this confirmed session?</h2>
      <p>The learner refund and tutor consequence are calculated automatically.</p>
      <div class="bk-cancellation-details" id="tutorCancellationDetails"></div>
      <p class="bk-issue-response-error" id="tutorCancellationError" role="alert"></p>
      <div class="bk-completion-actions">
        <button type="button" class="bk-completion-cancel" data-close-tutor-cancellation>Keep Session</button>
        <button type="button" class="bk-cancellation-confirm" id="confirmTutorCancellationBtn">Confirm Cancellation</button>
      </div>
    </div>
  </div>

  <div class="bk-toast" id="bookingToast" role="status" aria-live="polite" hidden></div>

  <script src="~/main-js/auth-guard.js"></script>
  <script>
    requireRole("tutor");
  </script>



  <script src="~/tutor/tutor-js/tutor-shared.js"></script>
  <script src="~/tutor/tutor-js/bookings.js"></script>
</body>
</html>
