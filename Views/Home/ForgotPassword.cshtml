@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password | Skolar</title>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="~/assets/img/skolarlogo.png">
    <link rel="stylesheet" href="~/css/skolar-dialog.css" asp-append-version="true">
    <link rel="stylesheet" href="~/main-css/forgot-password.css" asp-append-version="true">

    <style>
        /* OTP input row */
        .otp-row {
        display: flex;
        gap: 6px;
        justify-content: center;
        margin-bottom: 16px;
        width: 100%;
    }

    .otp-row input {
        width: 48px;
        height: 60px;
        text-align: center;
        font-size: 24px;
        font-weight: 700;
        background-color: #0d4f6c !important;
        color: #ffffff !important;
        border: 2px solid #ffffff;
        border-radius: 8px;
        outline: none;
        transition: border-color .2s;
        padding: 0;
        box-sizing: border-box;
    }
        .otp-row input:focus { border-color: #0d4f6c; }
        .resend-text { font-size: 13px; color: #888; text-align: center; }
        .resend-text button {
            background: none; border: none;
            color: #c0392b; cursor: pointer;
            font-size: 13px; font-weight: 600;
            padding: 0; text-decoration: underline;
        }
        .resend-text button:disabled { color: #aaa; cursor: default; text-decoration: none; }
        #otpTimer { font-weight: 600; color: #0d4f6c; }
    </style>
</head>

<body>
    <main class="forgot-page">
        <section class="forgot-left">
            <div class="forgot-box">

                <h2 id="forgotTitle">Forgot Password</h2>
                <p class="forgot-subtitle" id="forgotSubtitle">
                    Enter your registered email address first, then create a new password.
                </p>

                <!-- STEP 1: EMAIL -->
                <form id="emailForm" class="forgot-form active" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="email" id="resetEmail" name="resetEmail"
                           placeholder="Email Address" autocomplete="email"
                           maxlength="254" required>
                    <button type="submit" class="main-reset-btn">Continue</button>
                    <p class="switch-text">
                        Remember your password?
                        <a id="backToLogin" href="#">Log in</a>
                    </p>
                </form>

                <!-- STEP 2: OTP -->
                <form id="otpForm" class="forgot-form" novalidate>
                    <div class="otp-row">
                        <input type="text" inputmode="numeric" maxlength="1" class="otp-digit">
                        <input type="text" inputmode="numeric" maxlength="1" class="otp-digit">
                        <input type="text" inputmode="numeric" maxlength="1" class="otp-digit">
                        <input type="text" inputmode="numeric" maxlength="1" class="otp-digit">
                        <input type="text" inputmode="numeric" maxlength="1" class="otp-digit">
                        <input type="text" inputmode="numeric" maxlength="1" class="otp-digit">
                    </div>
                    <p class="resend-text">
                        Didn't get a code?
                        <button type="button" id="resendBtn" disabled>
                            Resend (<span id="otpTimer">60</span>s)
                        </button>
                    </p>
                    <button type="submit" class="main-reset-btn">Verify Code</button>
                    <p class="switch-text">
                        <a href="#" id="backToEmail">← Back</a>
                    </p>
                </form>

                <!-- STEP 3: RESET PASSWORD -->
                <form id="resetForm" class="forgot-form" novalidate>
                    <div class="password-wrapper">
                        <input type="password" id="newPassword" name="newPassword"
                               placeholder="New Password" autocomplete="new-password"
                               minlength="8" maxlength="64" required>
                        <button type="button" class="eye-btn"
                                onclick="togglePassword('newPassword', this)">👁</button>
                    </div>
                    <div class="password-wrapper">
                        <input type="password" id="confirmNewPassword" name="confirmNewPassword"
                               placeholder="Confirm Password" autocomplete="new-password"
                               minlength="8" maxlength="64" required>
                        <button type="button" class="eye-btn"
                                onclick="togglePassword('confirmNewPassword', this)">👁</button>
                    </div>
                    <button type="submit" class="main-reset-btn">Reset Password</button>
                    <p class="switch-text">Back to <a id="backToLoginTwo" href="#">Log in</a></p>
                </form>

                <p id="forgotMessage" role="status" aria-live="polite"></p>
            </div>
        </section>

        <section class="forgot-right">
            <img src="~/assets/img/skolar-logo-colored.png"
                 alt="Skolar Logo" class="skolar-logo-forgot">
        </section>
    </main>

    <script src="~/js/skolar-dialog.js" asp-append-version="true"></script>
    <script src="~/main-js/forgot-password.js" asp-append-version="true"></script>
</body>
</html>
