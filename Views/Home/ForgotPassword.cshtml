@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/skolar-dialog.css">
    <title>Forgot Password | Skolar</title>
    <link rel="icon" type="image/png" href="~/assets/img/skolarlogo.png">
    <link rel="stylesheet" href="~/main-css/forgot-password.css">
</head>
<body>
    <script src="~/js/skolar-dialog.js"></script>

    <main class="forgot-page">

        <section class="forgot-left">
            <div class="forgot-box">

                <h2 id="forgotTitle">Forgot Password</h2>

                <p class="forgot-subtitle">
                    Enter your registered email address first, then create a new password.
                </p>

                <!-- STEP 1: EMAIL -->
                <form id="emailForm" class="forgot-form active">
                    <input type="email" id="resetEmail" placeholder="Email Address" required>

                    <button type="submit" class="main-reset-btn">Continue</button>

                    <p class="switch-text">
                        Remember your password?
                        <a id="backToLogin" href="#">Log in</a>
                    </p>
                </form>

                <!-- STEP 2: RESET PASSWORD -->
                <form id="resetForm" class="forgot-form">
                    <div class="password-wrapper">
                        <input type="password" id="newPassword" placeholder="New Password" required>
                        <button type="button" class="eye-btn" onclick="togglePassword('newPassword', this)">👁</button>
                    </div>

                    <div class="password-wrapper">
                        <input type="password" id="confirmNewPassword" placeholder="Confirm Password" required>
                        <button type="button" class="eye-btn" onclick="togglePassword('confirmNewPassword', this)">👁</button>
                    </div>

                    <button type="submit" class="main-reset-btn">Reset Password</button>

                    <p class="switch-text">
                        Back to
                        <a id="backToLoginTwo" href="#">Log in</a>
                    </p>
                </form>

                <p id="forgotMessage"></p>
            </div>
        </section>

        <section class="forgot-right">
            <img src="~/assets/img/skolar-logo-colored.png" alt="Skolar Logo" class="skolar-logo-forgot">
        </section>

    </main>

    <script src="~/main-js/forgot-password.js"></script>
</body>
</html>
