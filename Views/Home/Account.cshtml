@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/skolar-dialog.css">
    <title>Skolar Login</title>
    <link rel="icon" type="image/png" href="~/assets/img/skolarlogo.png">
    <link rel="stylesheet" href="~/main-css/account-login.css">
</head>
<body>
    <script src="~/js/skolar-dialog.js"></script>

    <main class="account-page">

        <section class="account-left">
            <div class="account-box">

                <h2 id="roleTitle">Learner Login</h2>

                <form id="loginForm" class="account-form active">
                    @Html.AntiForgeryToken()
                    <input type="email" id="loginUsername" placeholder="Email Address" required>

                    <div class="password-wrapper">
                        <input type="password" id="loginPassword" placeholder="Password" required>
                        <button type="button" class="eye-btn" onclick="togglePassword('loginPassword', this)" aria-label="Show password">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12s3.5-7 9-7 9 7 9 7-3.5 7-9 7-9-7-9-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        </button>
                    </div>

                    <div class="form-options">
                        <a href="#" id="forgotPasswordLink">Forgot Password?</a>
                    </div>

                    <button type="submit" class="main-login-btn">Log in</button>

                    <p class="switch-text">
                        Don’t have an account?
                        <a id="goToSignup" href="#">Sign up</a>
                    </p>
                </form>

                <form id="loginOtpForm" class="account-form verification-form" novalidate>
                    <p class="verification-description">
                        Enter the six-digit code sent to
                        <strong id="loginMaskedEmail">your email</strong>.
                    </p>

                    <input
                        type="text"
                        id="loginOtp"
                        class="otp-input"
                        placeholder="000000"
                        inputmode="numeric"
                        autocomplete="one-time-code"
                        maxlength="6"
                        pattern="[0-9]{6}"
                        aria-label="Six-digit verification code"
                        required>

                    <button type="submit" class="main-login-btn">Verify and continue</button>

                    <div class="verification-actions">
                        <button type="button" id="resendLoginOtp" class="verification-link">Resend code</button>
                        <button type="button" id="backToLogin" class="verification-link">Back to login</button>
                    </div>
                </form>

                <p id="accountMessage" role="status" aria-live="polite"></p>
            </div>
        </section>

        <section class="account-right">
            <img src="~/assets/img/skolar-logo-colored.png" alt="Skolar Logo" class="skolar-logo-signup">
        </section>

    </main>

    <script src="~/main-js/account.js"></script>
</body>
</html>
