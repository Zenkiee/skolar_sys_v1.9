@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/skolar-dialog.css">
    <title>Skolar Login</title>
    <link rel="icon" type="image/png" href="~/assets/img/skolarlogo.png">
    <link rel="stylesheet" href="~/main-css/account-login.css">
</head>
<body>
    <script src="~/js/skolar-dialog.js"></script>

    <main class="account-page">

        <section class="account-left">
            <div class="account-box">

                <h2 id="roleTitle">Learner Login</h2>

                <form id="loginForm" class="account-form active">
                    <input type="email" id="loginUsername" placeholder="Email Address" required>

                    <div class="password-wrapper">
                        <input type="password" id="loginPassword" placeholder="Password" required>
                        <button type="button" class="eye-btn" onclick="togglePassword('loginPassword', this)">👁</button>
                    </div>

                    <div class="form-options">
                        <label>
                            <input type="checkbox">
                            <span>Remember me</span>
                        </label>

                        <a href="#" id="forgotPasswordLink">Forgot Password?</a>
                    </div>

                    <button type="submit" class="main-login-btn">Log in</button>

                    <p class="switch-text">
                        Don’t have an account?
                        <a id="goToSignup" href="#">Sign up</a>
                    </p>
                </form>

                <p id="accountMessage"></p>
            </div>
        </section>

        <section class="account-right">
            <img src="~/assets/img/skolar-logo-colored.png" alt="Skolar Logo" class="skolar-logo-signup">
        </section>

    </main>

    <script src="~/main-js/account.js"></script>
</body>
</html>
