@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/skolar-dialog.css">
    <title>Skolar Sign Up</title>
    <link rel="icon" type="image/png" href="~/assets/img/skolarlogo.png">
    <link rel="stylesheet" href="~/main-css/account-signup.css">
</head>
<body>
    <script src="~/js/skolar-dialog.js"></script>

    <main class="account-page">

        <!-- LEFT SIDE -->
        <section class="account-left">
            <div class="account-box" id="signupBox">

                <h2 id="roleTitle">Learner Sign Up</h2>

                <div class="signup-stepper">
                    <div class="signup-step active" id="stepOneCircle">1</div>
                    <div class="signup-line"></div>
                    <div class="signup-step" id="stepTwoCircle">2</div>
                </div>

                <p class="signup-step-label" id="stepLabel">Basic Account</p>

                <!-- STEP 1: BASIC SIGN UP -->
                <form id="basicSignupForm" class="account-form active">
                    <input type="email" id="signupEmail" placeholder="Email Address" required>

                    <div class="password-wrapper">
                        <input type="password" id="signupPassword" placeholder="Password" required>
                        <button type="button" class="eye-btn" onclick="togglePassword('signupPassword', this)">👁</button>
                    </div>

                    <div class="password-wrapper">
                        <input type="password" id="confirmPassword" placeholder="Confirm Password" required>
                        <button type="button" class="eye-btn" onclick="togglePassword('confirmPassword', this)">👁</button>
                    </div>

                    <label class="terms-check">
                        <input type="checkbox" id="agreeTerms" required>
                        <span>
                            I agree to the
                            <a href="#" id="termsLink">Terms and Conditions.</a>
                        </span>
                    </label>

                    <button type="submit" class="main-login-btn">Continue</button>

                    <p class="switch-text">
                        Already have an account?
                        <a id="goToLogin" href="#">Log in</a>
                    </p>
                </form>

                <!-- STEP 2A: LEARNER PROFILE -->
                <form id="learnerProfileForm" class="account-form profile-form-signup">
                    <input type="text" id="learnerName" placeholder="Learner Name" required>

                    <select id="yearLevel" required>
                        <option value="">Select Year Level</option>
                        <option>Preschool</option>
                        <option>Kindergarten</option>
                        <option>Grade 1</option>
                        <option>Grade 2</option>
                        <option>Grade 3</option>
                        <option>Grade 4</option>
                        <option>Grade 5</option>
                        <option>Grade 6</option>
                        <option>Junior High School</option>
                        <option>Senior High School</option>
                        <option>College</option>
                    </select>

                    <input type="text" id="school" placeholder="School">
                    <input type="date" id="birthday">

                    <div class="profile-buttons">
                        <button type="button" class="back-profile-btn" onclick="goBackToSignup()">Back</button>
                        <button type="submit" class="main-login-btn">Create Profile</button>
                    </div>
                </form>

                <!-- STEP 2B: TUTOR PROFILE -->
                <form id="tutorProfileForm" class="account-form profile-form-signup">
                    <input type="text" id="tutorName" placeholder="Tutor Name" required>
                    <input type="text" id="rate" placeholder="Hourly Rate e.g. ₱300/hr" required>
                    <input type="text" id="education" placeholder="Education / Course">
                    <input type="text" id="contactNumber" placeholder="Contact Number">
                    <textarea id="bio" placeholder="Short Bio"></textarea>

                    <input type="text" id="tutorSubjects" placeholder="Subjects e.g. Math, English, Reading" required>

                    <div class="profile-buttons">
                        <button type="button" class="back-profile-btn" onclick="goBackToSignup()">Back</button>
                        <button type="submit" class="main-login-btn">Create Profile</button>
                    </div>
                </form>

                <p id="accountMessage"></p>
            </div>
        </section>

        <!-- RIGHT SIDE -->
        <section class="account-right">
            <img src="~/assets/img/skolar-logo-colored.png" alt="Skolar Logo" class="skolar-logo-signup">
        </section>

    </main>

    <script src="~/main-js/signup.js"></script>
</body>
</html>
